PORT=4080

# Step 2 — required for Railway (also defaulted in railway.toml + Dockerfile)
NOVAPAY_SANDBOX_BASE=https://nova-bank-api-production-7311.up.railway.app/api/v1/partners/novapay/sandbox

# Optional bearer for /api/v1/novapay/* (leave empty for open sandbox)
NOVAPAY_API_KEY=
# Optional HMAC secret for POST /api/v1/webhooks/novapay
NOVAPAY_WEBHOOK_SECRET=
# Step 3 — public https origin after Railway domain is assigned
PUBLIC_BASE_URL=
