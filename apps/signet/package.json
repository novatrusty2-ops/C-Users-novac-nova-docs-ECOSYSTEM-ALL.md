{
  "name": "signet-wallet",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "Signet Wallet — regal institutional self-custody SPA (signetwallet.com). Separate product from Nova Wallet.",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "brand:sync": "node scripts/brand-sync.mjs",
    "brand:extract": "node scripts/brand-extract.mjs",
    "brand:icons": "node scripts/brand-icons.mjs",
    "gate": "node server/gate/index.mjs",
    "deploy": "bash ./deploy.sh"
  },
  "dependencies": {
    "@safe-global/api-kit": "^4.0.1",
    "@safe-global/protocol-kit": "^6.1.2",
    "@walletconnect/web3wallet": "^1.16.1",
    "ethers": "^6.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
