{
  "name": "nova-wallet",
  "version": "1.0.0",
  "private": true,
  "description": "Nova Wallet — https://novablockchain.it.com/",
  "workspaces": [
    "apps/nova"
  ],
  "scripts": {
    "dev": "npm run dev -w nova-wallet",
    "dev:nova": "npm run dev -w nova-wallet",
    "build": "npm run build -w nova-wallet",
    "build:nova": "npm run build -w nova-wallet",
    "test": "npm run test -w nova-wallet",
    "test:nova": "npm run test -w nova-wallet",
    "typecheck": "npm run typecheck -w nova-wallet",
    "fetch-api": "bash scripts/fetch-api.sh",
    "sync": "python3 scripts/sync-ecosystem.py",
    "sync:ecosystem": "bash scripts/fetch-api.sh && python3 scripts/sync-ecosystem.py",
    "verify:ecosystem": "node scripts/verify-ecosystem.mjs",
    "swap:ausdt-eth": "node scripts/live-swap-ausdt-eth.mjs",
    "swap:ausdt-eth:70k": "SWAP_AMOUNT=70000 node scripts/live-swap-ausdt-eth.mjs",
    "swap:ausdt-bnb": "node scripts/live-swap-ausdt-bnb.mjs",
    "swap:usdt-bnb": "node scripts/live-swap-usdt-bnb.mjs",
    "swap:usdt-bnb:70k": "SWAP_AMOUNT=70000 node scripts/live-swap-usdt-bnb.mjs",
    "settle:usdt-trc20": "node scripts/live-settle-usdt-trc20.mjs",
    "settle:usdt-trc20:70k": "SWAP_AMOUNT=70000 node scripts/live-settle-usdt-trc20.mjs",
    "withdraw:eth-onex": "node scripts/live-withdraw-eth-onex.mjs",
    "verify:custody": "node scripts/verify-custody-creds.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
