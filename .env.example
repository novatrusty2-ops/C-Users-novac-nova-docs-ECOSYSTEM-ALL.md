# =============================================================================
# Nova Bank Malta Ltd · OpenPayd EMI — environment template
# =============================================================================
# This ecosystem/wallet repository does NOT load these secrets at runtime.
# Set them on the Nova Bank NestJS API host (Railway / local .env) that owns
# the OpenPayd client. Never commit real values.
#
# Live Nova catalog hint:
#   GET /api/v1/international/integrations → id=openpayd
#   configHint: EMI_OPENPAYD_API_KEY
# Live Malta signal:
#   GET /api/v1/global/status → features.malta.emiPartner = openpayd
# Docs:
#   docs/OPENPAYD-NOVA-BANK-MALTA-SETUP.md
#   https://apidocs.openpayd.com/
# =============================================================================

# --- Required for NestJS Nova Bank API (Railway) ---

# Catalog config hint from Nova Bank international integrations.
EMI_OPENPAYD_API_KEY=

# OpenPayd OAuth username + password (Basic auth → client_credentials token).
# Obtain from the OpenPayd partner portal for the Nova Bank Malta Ltd account.
OPENPAYD_USERNAME=
OPENPAYD_PASSWORD=

# Account holder UUID returned by OAuth (also sent as x-account-holder-id).
OPENPAYD_ACCOUNT_HOLDER_ID=

# API base URL (no trailing slash).
# Sandbox: https://sandbox.openpayd.com
# Production: confirm with OpenPayd (commonly https://api.openpayd.com or tenant URL).
OPENPAYD_BASE_URL=https://sandbox.openpayd.com

# Environment label used by NestJS feature flags / logging.
# Values: sandbox | production
OPENPAYD_ENV=sandbox

# --- Strongly recommended ---

# Default EUR (or multi-currency) payment account id for Nova Bank Malta Ltd.
OPENPAYD_ACCOUNT_ID=

# Linked client / referral identifiers if OpenPayd issued them for this entity.
OPENPAYD_CLIENT_ID=
OPENPAYD_REFERRAL_ID=

# Webhook HMAC / signing secret from OpenPayd webhook setup.
OPENPAYD_WEBHOOK_SECRET=

# Public HTTPS URL on Nova Bank API that receives OpenPayd events.
# Example: https://nova-bank-api-production-7311.up.railway.app/api/v1/webhooks/openpayd
OPENPAYD_WEBHOOK_URL=

# Legal / settlement context (not secrets; useful for ops runbooks).
OPENPAYD_LEGAL_ENTITY=Nova Bank Malta Ltd
OPENPAYD_SETTLEMENT_CURRENCY=EUR
# Settlement IBAN / BIC — fill from OpenPayd portal / compliance (not in git).
OPENPAYD_SETTLEMENT_IBAN=
OPENPAYD_SETTLEMENT_BIC=

# --- Optional NestJS toggles (names may vary in the NestJS repo) ---

# Force banking provider selection when wiring EMI rails.
# BANKING_PROVIDER=openpayd

# When true, NestJS should use live OpenPayd instead of sandbox banking mocks.
# OPENPAYD_LIVE=false

# Idempotency / timeout knobs if implemented by the NestJS client.
# OPENPAYD_HTTP_TIMEOUT_MS=30000
# OPENPAYD_MAX_RETRIES=3

# --- This ecosystem repo only (unrelated to OpenPayd) ---

# NOVA_BANK_API=https://nova-bank-api-production-7311.up.railway.app/api/v1
# VITE_BASE=/
# VITE_WALLETCONNECT_PROJECT_ID=
# GATE_PORT=8787
# GATE_ACCESS_CODE=signet-institutional
# VITE_GATE_URL=http://localhost:8787
