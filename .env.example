# Nova Bank production wire payout (scripts/wire-fiat-payout.mjs)
NOVA_BANK_API_BASE=https://nova-bank-api-production-7311.up.railway.app/api/v1

# Auth: bearer token OR email+pin via POST /auth/start
NOVA_BANK_TOKEN=
NOVA_BANK_EMAIL=
NOVA_BANK_PIN=

# Wire rail — POST /wire/send
WIRE_AMOUNT=100000.00
WIRE_CURRENCY=USD
WIRE_FROM_ACCOUNT_ID=
WIRE_BENEFICIARY_NAME=
WIRE_BENEFICIARY_IBAN=
WIRE_BENEFICIARY_SWIFT=
WIRE_CHARGE_BEARER=SHA
WIRE_PIN=

# Set to 1 only when ready to submit a live production wire
WIRE_LIVE=0
