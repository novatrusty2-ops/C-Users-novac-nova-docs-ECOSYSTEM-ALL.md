# Nova Bank / hybrid live swap tests
# npm run swap:ausdt-eth
# npm run swap:ausdt-eth:70k
# npm run swap:ausdt-bnb
# npm run swap:usdt-bnb
# npm run swap:usdt-bnb:70k
# npm run settle:usdt-trc20:70k   # replaces BNB settle (USD → USDT_TRC20 exchange)
NOVA_BANK_API_BASE=https://nova-bank-api-production-7311.up.railway.app/api/v1
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# Quote-only / plan (default). Use 70000 for 70k tests.
SWAP_AMOUNT=10
SWAP_USDC_BUFFER=0.05
# SWAP_SLIPPAGE_BPS=50
# USD_ACCOUNT_NUMBER=4599

# Execute (ETH two-hop / USDT_TRC20 exchange)
# PIN optional when /auth/start returns tokens for email alone
SWAP_LIVE=0
NOVA_BANK_TOKEN=
NOVA_BANK_EMAIL=
NOVA_BANK_PIN=
