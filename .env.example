# =============================================================================
# Nova Bank · NovaPay partner wiring — environment template
# =============================================================================
# This ecosystem/wallet repository does NOT load these secrets at runtime.
# Set them on the Nova Bank NestJS API host (Railway / local .env).
# Never commit real values.
#
# Live sandbox:
#   GET /api/v1/partners/novapay/sandbox/status
# Docs:
#   docs/NOVAPAY-NOVA-BANK-WIRING.md
#   patches/nova-bank-api/novapay-partner/README.md
# =============================================================================

# --- NovaPay partner (NestJS on Railway) ---

NOVAPAY_ENABLED=true
NOVAPAY_MODE=sandbox
NOVAPAY_SANDBOX_BASE=https://nova-bank-api-production-7311.up.railway.app/api/v1/partners/novapay/sandbox
NOVAPAY_WEBHOOK_URL=https://nova-bank-api-production-7311.up.railway.app/api/v1/webhooks/novapay
NOVAPAY_WEBHOOK_SECRET=
NOVAPAY_CALLBACK_PATH=/api/v1/webhooks/novapay
NOVAPAY_HTTP_TIMEOUT_MS=30000

# Admin key for NestJS /novapay/health|receive|send|events (if used)
# ADMIN_API_KEY=

# --- Optional: local NestJS install target ---
# NOVA_API_ROOT=/path/to/nova/apps/api

# --- This ecosystem repo only ---
# NOVA_BANK_API=https://nova-bank-api-production-7311.up.railway.app/api/v1
# VITE_NOVAPAY_SANDBOX_BASE=https://nova-bank-api-production-7311.up.railway.app/api/v1/partners/novapay/sandbox
